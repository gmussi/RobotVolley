{
  "name": "robot-volley",
  "version": "0.1.0",
  "private": true,
  "description": "Robot Volley — a 1v1 slime-volley-style game with customizable robot athletes.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "genart": "python3 tools/genart.py",
    "genart:ai": "python3 tools/gen_nanobanana.py",
    "genart:stadium": "python3 tools/gen_stadium_layers.py",
    "genart:icons": "python3 tools/export_icons.py",
    "capture:shots": "node tools/capture_store_shots.mjs",
    "cap:sync": "npm run build && npx cap sync",
    "cap:android": "npx cap open android",
    "cap:ios": "npx cap open ios",
    "genaudio": "node tools/gen_audio.mjs",
    "encode:music": "bash tools/encode_match_music.sh"
  },
  "devDependencies": {
    "jsdom": "^24.0.0",
    "vite": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
